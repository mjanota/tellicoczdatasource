{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "-t \"Totalni raus\""
        },
        {
            "name": "Databazeknih py",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/databazeknih/.venv/bin/python",
            "program": "${workspaceFolder}/databazeknih/databazeknih_search.py",
            "cwd": "${workspaceFolder}/databazeknih",
            "console": "integratedTerminal",
            "args": [
                "-t",
                "${input:bookTitle}",
                "-d",
                "-c",
                "${input:bookCount}"
            ]
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug local",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/${relativeFile}",
            "exec": "perl",
            "execArgs": [],
            "root": "${workspaceRoot}/",
            "inc": [],
            "args": [
                "-t \"Muz, ktery se smeje\""
            ],
            "env": {},
            "debugRaw": false,
            "debugLog": false,
            "stopOnEntry": true,
            "sessions": "single"
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug remote",
            "console": "remote",
            "program": "${workspaceFolder}/${relativeFile}",
            "root": "${workspaceRoot}/",
            "stopOnEntry": true,
            "port": 5000,
            "sessions": "single"
        }
    ],
    "inputs": [
        {
            "id": "bookTitle",
            "type": "promptString",
            "description": "Nazev knihy (volitelne)",
            "default": ""
        },
        {
            "id": "bookCount",
            "type": "promptString",
            "description": "Pocet nalezenych knih (pro -c)",
            "default": "3"
        }
    ]
}